        "import random\n",
        "\n",
        "def get_intent(user_input):\n",
        "    user_input = user_input.lower()\n",
        "    for intent, data in intents.items():\n",
        "        for pattern in data[\"patterns\"]:\n",
        "            if pattern in user_input:\n",
        "                return intent\n",
        "    return \"unknown\"\n",
        "\n",
        "def get_commodity_price(user_input):\n",
        "    user_input = user_input.lower()\n",
        "    for commodity, price in commodities.items():\n",
        "        if commodity in user_input:\n",
        "            return f\"The current price of {commodity.title()} is ₹{price} per kg.\"\n",
        "    return None\n",
        "\n",
        "def list_all_commodities():\n",
        "    print(\"Bot: Available commodities and prices:\")\n",
        "    for commodity, price in commodities.items():\n",
        "        print(f\"     • {commodity.title():<12} ₹{price} per kg\")\n",
        "\n",
        "def chatbot():\n",
        "    print(\"Bot: Welcome! Ask me commodity prices or type 'list' to see all\")\n",
        "\n",
        "    waiting_for_commodity = False\n",
        "\n",
        "    while True:\n",
        "        user_input = input(\"You: \").strip()\n",
        "\n",
        "        if not user_input:\n",
        "            print(\"Bot: Please type something!\\n\")\n",
        "            continue\n",
        "\n",
        "        if waiting_for_commodity:\n",
        "            price_info = get_commodity_price(user_input)\n",
        "            if price_info:\n",
        "                print(f\"Bot: {price_info}\\n\")\n",
        "            else:\n",
        "                print(f\"Bot: Sorry, '{user_input}' is not in our list.Type 'list' to see available commodities.\\n\")\n",
        "            waiting_for_commodity = False\n",
        "            continue\n",
        "\n",
        "        price_info = get_commodity_price(user_input)\n",
        "        if price_info:\n",
        "            print(f\"Bot: {price_info}\\n\")\n",
        "            continue\n",
        "\n",
        "        intent = get_intent(user_input)\n",
        "\n",
        "        if intent == \"greeting\":\n",
        "            print(f\"Bot: {random.choice(intents[intent]['responses'])}\\n\")\n",
        "\n",
        "        elif intent == \"price_query\":\n",
        "            print(f\"Bot: {random.choice(intents[intent]['responses'])}\\n\")\n",
        "            waiting_for_commodity = True\n",
        "\n",
        "        elif intent == \"list_commodities\":\n",
        "            list_all_commodities()\n",
        "            print()\n",
        "\n",
        "        elif intent == \"goodbye\":\n",
        "            print(f\"Bot: {random.choice(intents[intent]['responses'])}\")\n",
        "            break\n",
        "\n",
        "        else:\n",
        "            print(\"Bot: I don't understand. Try asking for a price or type 'list'.\\n\")\n",
        "\n",
        "chatbot()"
      ]
